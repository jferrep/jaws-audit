# /etc/jaws-audit.conf
# Configuración para jaws-audit-check.sh y jaws-audit-full.sh
# Credenciales sensibles — NO añadir a git

# Telegram
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""

# Umbrales
DISK_THRESHOLD=80       # % de uso de disco para alertar
SSH_FAIL_THRESHOLD=500  # intentos fallidos por semana para alertar
